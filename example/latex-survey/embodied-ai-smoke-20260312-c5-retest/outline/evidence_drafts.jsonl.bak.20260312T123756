ance": {"evidence_level": "abstract", "source": "paper_notes", "pointer": "papers/paper_notes.jsonl:paper_id=P0112#key_results[0]"}}, {"evidence_id": "E-P0235-75ac11b564", "text": "We train CrossFormer on the largest and most diverse dataset to date, 900K trajectories across 20 different robot embodiments.", "paper_id": "P0235", "citations": ["Doshi2024Scaling"], "provenance": {"evidence_level": "abstract", "source": "paper_notes", "pointer": "papers/paper_notes.jsonl:paper_id=P0235#key_results[0]"}}, {"evidence_id": "E-P0122-56fa221ab5", "text": "We obtain state-of-the-art results across multiple manipulation and navigation benchmarks, as well as real-robot deployments.", "paper_id": "P0122", "citations": ["Bu2025Univla"], "provenance": {"evidence_level": "abstract", "source": "paper_notes", "pointer": "papers/paper_notes.jsonl:paper_id=P0122#key_results[0]"}}, {"evidence_id": "E-P0165-d133648b1e", "text": "Evaluations are critical to assess progress and build better policies, but evaluation in the real world, especially at a scale that would provide statistically reliable results, is costly in terms of human time and hard to obtain.", "paper_id": "P0165", "citations": ["Zhou2025Autoeval"], "provenance": {"evidence_level": "abstract", "source": "paper_notes", "pointer": "papers/paper_notes.jsonl:paper_id=P0165#key_results[1]"}}, {"evidence_id": "E-P0271-6cfd187893", "text": "However, acquiring datasets that comprehensively cover diverse tasks and environments is extremely costly and difficult to scale.", "paper_id": "P0271", "citations": ["Dai2026Conla"], "provenance": {"evidence_level": "abstract", "source": "paper_notes", "pointer": "papers/paper_notes.jsonl:paper_id=P0271#key_results[1]"}}, {"evidence_id": "E-P0297-1332cb791b", "text": "An analysis of existing robotics benchmarks reveals that successful task performance hinges on three key whole-body control capabilities: bimanual coordination, stable and precise navigation, and extensive end-effector reachabili