{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "taxonomy-builder domain pack",
  "type": "object",
  "required": ["profile", "detect", "taxonomy"],
  "properties": {
    "profile": {"type": "string"},
    "display_name": {"type": "string"},
    "compatibility_mode": {"type": "string"},
    "detect": {
      "type": "object",
      "properties": {
        "all_of_groups": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        },
        "any_of": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "representative_papers": {
      "type": "object",
      "properties": {
        "top_level_max": {"type": "integer", "minimum": 1},
        "suffix_template": {"type": "string"}
      },
      "additionalProperties": true
    },
    "taxonomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description_base", "children"],
        "properties": {
          "name": {"type": "string"},
          "description_base": {"type": "string"},
          "representative_terms": {
            "type": "array",
            "items": {"type": "string"}
          },
          "children": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": {"type": "string"},
                "description": {"type": "string"}
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
