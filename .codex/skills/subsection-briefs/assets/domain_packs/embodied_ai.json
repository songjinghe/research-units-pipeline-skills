  "thesis_rules": [
    {
      "match_any": [
        "manipulation",
        "navigation",
        "task scope"
      ],
      "template": "The central comparison in {title} is not raw capability in the abstract but which task and embodiment assumptions remain stable once interfaces and evaluation settings change."
    },
    {
      "match_any": [
        "observation",
        "action",
        "embodiment interface"
      ],
      "template": "In {title}, the key divide is between richer perceptual or action interfaces and the execution stability needed to turn those interfaces into controllable behavior."
    },
    {
      "match_any": [
        "task diversity",
        "environment realism",
        "transfer constraints"
      ],
      "template": "For {title}, the important question is which gains survive a shift in embodiment, environment, or task distribution rather than staying confined to the original training scope."
    },
    {
      "match_any": [
        "vision-language-action",
        "vla",
        "policy backbone"
      ],
      "template": "In {title}, the useful comparison is between larger multimodal backbones and tighter action-centric control routes, because added modeling capacity only matters when grounding and latency remain tractable."
    },
    {
      "match_any": [
        "pretraining data",
        "data and supervision",
        "pretrain",
        "post-training",
        "finetun"
      ],
      "template": "In {title}, the real distinction is not simply more data versus less data, but which supervision source and adaptation recipe still transfer beyond the original embodiment or benchmark slice."
    },
    {
      "match_any": [
        "benchmarks",
        "metrics",
        "generalization"
      ],
      "template": "In {title}, benchmark gains only become meaningful once task realism, metric choice, and cross-embodiment generalization are read as part of the same evaluation contract."
    },
    {
      "match_any": [
        "safety",
        "reliability",
        "deployment"
      ],
      "template": "In {title}, the main issue is whether reported robustness survives deployment constraints such as latency, partial observability, and real-world recovery demands."
    },
    {
      "match_any": [
        "failure analysis",
        "robustness",
        "stress testing"
      ],
      "template": "In {title}, the most useful evidence comes from stress cases that isolate why a system breaks, not just from aggregate robustness scores."
    }
  ],
  "tension_rules": [
    {
      "match_any": [
        "manipulation",
        "navigation",
        "mobile",
        "humanoid"
      ],
      "template": "In {title}, a central tension is task generality versus embodiment specificity: systems that look broadly capable often rely on interfaces, sensors, or embodiments that make transfer harder than headline results suggest."
    },
    {
      "match_any": [
        "vision-language-action",
        "vla",
        "policy",
        "action",
        "control"
      ],
      "template": "In {title}, a recurring tension is expressive policy conditioning versus executable control reliability: richer multimodal policies promise broader competence, but they often expose new latency, stability, or action-grounding failures."
    },
    {
      "match_any": [
        "world model",
        "planning",
        "reasoning",
        "memory"
      ],
      "template": "In {title}, a key tension is deliberation depth versus control robustness: more planning or internal modeling can improve long-horizon reasoning, but it also raises synchronization, observability, and execution-risk questions."
    },
    {
      "match_any": [
        "evaluation",
        "benchmark",
        "safety",
        "deploy",
        "sim2real"
      ],
      "template": "In {title}, the main tension is benchmark success versus deployment realism: strong results in curated settings do not automatically translate into safe, reliable embodied behavior under real-world constraints."
    },
    {
      "match_any": [
        "task diversity",
        "environment realism",
        "transfer constraints"
      ],
      "template": "In {title}, the key tension is breadth versus transfer reliability: covering diverse tasks and environments improves scope, but it also exposes sharper failures when embodiments, sensors, or deployment conditions shift."
    },
    {
      "match_any": [
        "data quality",
        "distribution shift",
        "scaling"
      ],
      "template": "In {title}, a recurring tension is scale versus data fidelity: larger embodied corpora improve coverage, but noisy supervision, heterogeneous sources, and distribution shift can erode downstream robustness."
    },
    {
      "match_any": [
        "pretraining data",
        "data and supervision",
        "pretrain",
        "post-training",
        "finetun"
      ],
      "template": "In {title}, the main tension is data breadth versus transfer fidelity: larger and more diverse supervision improves coverage, but heterogeneous corpora and weak alignment often make cross-embodiment gains fragile."
    },
    {
      "match_any": [
        "failure analysis",
        "robustness",
        "stress testing"
      ],
      "template": "In {title}, the central tension is broad stress coverage versus actionable diagnosis: wider robustness testing reveals more failure modes, but it can also blur which mechanism or deployment factor actually caused the breakdown."
    }
  ]
