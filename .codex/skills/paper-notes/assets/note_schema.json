{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PaperNote",
    "description": "Schema for a single paper note record in papers/paper_notes.jsonl",
    "type": "object",
    "required": [
        "paper_id",
        "title",
        "bibkey",
        "evidence_level",
        "priority",
        "summary_bullets",
        "limitations"
    ],
    "properties": {
        "paper_id": {
            "type": "string"
        },
        "title": {
            "type": "string"
        },
        "year": {
            "oneOf": [
                {
                    "type": "integer"
                },
                {
                    "type": "string"
                }
            ]
        },
        "url": {
            "type": "string"
        },
        "arxiv_id": {
            "type": "string"
        },
        "primary_category": {
            "type": "string"
        },
        "categories": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "pdf_url": {
            "type": "string"
        },
        "priority": {
            "type": "string",
            "enum": [
                "high",
                "normal"
            ]
        },
        "mapped_sections": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "evidence_level": {
            "type": "string",
            "enum": [
                "fulltext",
                "abstract",
                "title"
            ]
        },
        "fulltext_path": {
            "type": "string"
        },
        "authors": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "abstract": {
            "type": "string"
        },
        "summary_bullets": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1
        },
        "method": {
            "type": "string"
        },
        "key_results": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "limitations": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1
        },
        "bibkey": {
            "type": "string"
        }
    }
}