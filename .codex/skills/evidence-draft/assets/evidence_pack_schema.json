{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/evidence-pack.schema.json",
  "title": "Evidence Draft Pack",
  "type": "object",
  "required": [
    "sub_id",
    "title",
    "evidence_ids",
    "evidence_level_summary",
    "evidence_snippets",
    "definitions_setup",
    "claim_candidates",
    "concrete_comparisons",
    "evaluation_protocol",
    "failures_limitations",
    "blocking_missing",
    "verify_fields",
    "generated_at"
  ],
  "properties": {
    "sub_id": {"type": "string"},
    "title": {"type": "string"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_level_summary": {"type": "object"},
    "evidence_snippets": {"type": "array", "items": {"type": "object"}},
    "definitions_setup": {"type": "array", "items": {"type": "object"}},
    "claim_candidates": {"type": "array", "items": {"type": "object"}},
    "concrete_comparisons": {"type": "array", "items": {"type": "object"}},
    "evaluation_protocol": {"type": "array", "items": {"type": "object"}},
    "failures_limitations": {"type": "array", "items": {"type": "object"}},
    "blocking_missing": {"type": "array", "items": {"type": "string"}},
    "downgrade_signals": {"type": "array", "items": {"type": "string"}},
    "verify_fields": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": true
}
