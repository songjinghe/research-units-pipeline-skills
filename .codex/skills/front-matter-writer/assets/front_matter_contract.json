{
  "version": "1.0",
  "reference_pack": [
    "references/overview.md",
    "references/abstract_archetypes.md",
    "references/introduction_jobs.md",
    "references/related_work_positioning.md",
    "references/discussion_conclusion_patterns.md",
    "references/forbidden_stems.md",
    "references/examples_good.md",
    "references/examples_bad.md"
  ],
  "asset_pack": [
    "assets/front_matter_contract.json",
    "assets/front_matter_templates.json",
    "assets/front_matter_context.schema.json",
    "assets/front_matter_context_schema.json"
  ],
  "methodology_note_policy": {
    "placement": "introduction",
    "max_occurrences": 1,
    "required_fields": [
      "candidate_pool",
      "core_set_size",
      "evidence_mode",
      "time_window"
    ]
  },
  "voice_guardrails": {
    "forbidden_stems": [
      "for this run",
      "this review",
      "this survey",
      "the discussion below",
      "what follows",
      "the remaining sections",
      "that methodology note appears once here",
      "evidence assembled here",
      "pipeline",
      "workspace"
    ],
    "allow_self_narration": false,
    "allow_pipeline_voice": false
  },
  "sections": {
    "abstract": {
      "mode": "sentence_bank"
    },
    "introduction": {
      "mode": "job_graph",
      "jobs": [
        {
          "job": "motivation",
          "cite_start": 0,
          "cite_width": 6
        },
        {
          "job": "comparison_pressure",
          "cite_start": 6,
          "cite_width": 6
        },
        {
          "job": "lens_commitment",
          "cite_start": 12,
          "cite_width": 6
        },
        {
          "job": "boundary",
          "cite_start": 18,
          "cite_width": 6
        },
        {
          "job": "methodology_note",
          "cite_start": 24,
          "cite_width": 6
        },
        {
          "job": "closing_bridge",
          "cite_start": 30,
          "cite_width": 6
        }
      ]
    },
    "related_work": {
      "mode": "job_graph",
      "jobs": [
        {
          "job": "opening",
          "cite_start": 0,
          "cite_width": 6
        },
        {
          "job": "chapter_positioning",
          "repeat_from": "chapters",
          "limit": 4,
          "cite_start": 6,
          "cite_width": 6,
          "cite_stride": 6
        },
        {
          "job": "evaluation_calibration",
          "cite_start": 18,
          "cite_width": 6
        },
        {
          "job": "gap_statement",
          "cite_start": 24,
          "cite_width": 6
        },
        {
          "job": "closing_bridge",
          "cite_start": 30,
          "cite_width": 6
        }
      ]
    },
    "discussion": {
      "mode": "paragraph_bank"
    },
    "conclusion": {
      "mode": "paragraph_bank"
    }
  }
}
