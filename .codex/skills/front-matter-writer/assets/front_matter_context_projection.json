{
  "chapter_theme_rules": [
    {
      "match_any": ["problem settings", "embodiment"],
      "emit": "problem settings and embodiment assumptions"
    },
    {
      "match_any": ["model", "policy", "architecture"],
      "emit": "model and policy design"
    },
    {
      "match_any": ["data", "training", "post-training"],
      "emit": "data, supervision, and post-training strategy"
    },
    {
      "match_any": ["evaluation", "deployment", "safety"],
      "emit": "evaluation, safety, and deployment constraints"
    }
  ],
  "chapter_focus_policy": {
    "throughline_take": 2,
    "contrast_take": 1,
    "surface_limit": 120
  },
  "chapter_grouping_policy": {
    "default_max_groups": 2,
    "min_group_size": 2,
    "section_overrides": {
      "related_work": {
        "max_groups": 4
      }
    }
  },
  "global_value_projection": {
    "lens_take": 4,
    "comparison_take": 3
  }
}
