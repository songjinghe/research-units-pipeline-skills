{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/front-matter-context.schema.json",
  "title": "Front Matter Writer Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_contract",
    "sections",
    "inputs",
    "methodology_note_policy",
    "voice_guardrails",
    "reference_pack"
  ],
  "properties": {
    "artifact_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatible_with_current_pipeline",
        "reader_facing",
        "output_files"
      ],
      "properties": {
        "compatible_with_current_pipeline": {
          "type": "boolean"
        },
        "reader_facing": {
          "type": "boolean"
        },
        "output_files": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "enum": [
              "sections/abstract.md",
              "sections/S<sec_id>.md",
              "sections/discussion.md",
              "sections/conclusion.md"
            ]
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "must_include",
          "must_avoid"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "abstract",
              "introduction",
              "related_work",
              "discussion",
              "conclusion"
            ]
          },
          "role": {
            "type": "string",
            "minLength": 10
          },
          "must_include": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "must_avoid": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_files",
        "optional_files",
        "context_fields"
      ],
      "properties": {
        "required_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "optional_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "context_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "goal_boundary",
              "time_window",
              "candidate_pool_size",
              "core_set_size",
              "evidence_mode",
              "section_titles",
              "cross_cutting_citations",
              "scope_exclusions"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "methodology_note_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placement",
        "max_occurrences",
        "reader_facing_phrase"
      ],
      "properties": {
        "placement": {
          "type": "string",
          "enum": [
            "introduction",
            "related_work",
            "either_once"
          ]
        },
        "max_occurrences": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1
        },
        "reader_facing_phrase": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "voice_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbidden_stems",
        "allow_self_narration",
        "allow_pipeline_voice"
      ],
      "properties": {
        "forbidden_stems": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "allow_self_narration": {
          "type": "boolean"
        },
        "allow_pipeline_voice": {
          "type": "boolean"
        }
      }
    },
    "reference_pack": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "purpose",
          "load_when"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^references/.+\\.md$"
          },
          "purpose": {
            "type": "string",
            "minLength": 8
          },
          "load_when": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "asset_pack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^assets/.+"
      }
    },
    "template_asset": {
      "type": "string",
      "pattern": "^assets/.+\\.json$"
    }
  }
}
