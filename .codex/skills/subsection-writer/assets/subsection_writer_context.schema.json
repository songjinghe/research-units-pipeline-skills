{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/subsection-writer-context.schema.json",
  "title": "Subsection Writer Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "compatibility_mode",
    "output_contract",
    "reference_pack",
    "must_have_moves",
    "opener_modes",
    "guardrails"
  ],
  "properties": {
    "compatibility_mode": {"type": "boolean"},
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global_files", "h2_body_pattern", "h2_lead_pattern", "h3_body_pattern", "manifest_path"],
      "properties": {
        "global_files": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sections/abstract.md",
              "sections/discussion.md",
              "sections/conclusion.md"
            ]
          }
        },
        "h2_body_pattern": {"type": "string", "const": "sections/S<sec_id>.md"},
        "h2_lead_pattern": {"type": "string", "const": "sections/S<sec_id>_lead.md"},
        "h3_body_pattern": {"type": "string", "const": "sections/S<sub_id>.md"},
        "manifest_path": {"type": "string", "const": "sections/sections_manifest.jsonl"}
      }
    },
    "reference_pack": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose", "load_when"],
        "properties": {
          "path": {"type": "string", "pattern": "^references/.+\\.md$"},
          "purpose": {"type": "string", "minLength": 8},
          "load_when": {"type": "string", "minLength": 8}
        }
      }
    },
    "must_have_moves": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "thesis",
          "contrast",
          "evaluation_anchor",
          "cross_paper_synthesis",
          "limitation",
          "local_conclusion"
        ]
      },
      "uniqueItems": true
    },
    "opener_modes": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "tension-first",
          "contrast-first",
          "protocol-first",
          "failure-first",
          "decision-first",
          "lens-first"
        ]
      },
      "uniqueItems": true
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ban_fixed_paragraph_count", "ban_pipeline_voice", "ban_narration_openers"],
      "properties": {
        "ban_fixed_paragraph_count": {"type": "boolean"},
        "ban_pipeline_voice": {"type": "boolean"},
        "ban_narration_openers": {"type": "boolean"}
      }
    }
  }
}
