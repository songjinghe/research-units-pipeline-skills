{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/reference-first-skill.schema.json",
  "title": "Reference-First Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_name",
    "purpose",
    "reader_facing",
    "references",
    "assets",
    "script_capabilities",
    "script_non_goals",
    "guardrails"
  ],
  "properties": {
    "skill_name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9_][a-z0-9_-]*$"
    },
    "purpose": {
      "type": "string",
      "minLength": 10
    },
    "reader_facing": {
      "type": "boolean"
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "purpose",
          "load_when"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^references/.+\\.md$"
          },
          "purpose": {
            "type": "string",
            "minLength": 5
          },
          "load_when": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^assets/.+"
          },
          "role": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "script_capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "discovery",
          "normalization",
          "validation",
          "manifest",
          "external-tool"
        ]
      },
      "uniqueItems": true
    },
    "script_non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "reader_facing_hygiene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ban_internal_jargon",
        "ban_unresolved_placeholders",
        "require_complete_examples"
      ],
      "properties": {
        "ban_internal_jargon": {
          "type": "boolean"
        },
        "ban_unresolved_placeholders": {
          "type": "boolean"
        },
        "require_complete_examples": {
          "type": "boolean"
        }
      }
    }
  }
}
