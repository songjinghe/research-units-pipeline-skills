{
    "_comment": "Evidence bank tagging categories. Externalized from run.py so domain-specific tags can be added without code changes.",
    "tag_rules": [
        {
            "tag": "evaluation",
            "keywords": [
                "benchmark",
                "benchmarks",
                "dataset",
                "datasets",
                "metric",
                "metrics",
                "eval",
                "evaluation"
            ]
        },
        {
            "tag": "tooling",
            "keywords": [
                "tool",
                "tools",
                "api",
                "function call",
                "function-calling",
                "mcp",
                "schema"
            ]
        },
        {
            "tag": "memory",
            "keywords": [
                "memory",
                "retrieval",
                "rag",
                "cache"
            ]
        },
        {
            "tag": "security",
            "keywords": [
                "attack",
                "vulnerab",
                "prompt injection",
                "exfiltration",
                "jailbreak",
                "guardrail",
                "sandbox"
            ]
        },
        {
            "tag": "planning",
            "keywords": [
                "planning",
                "plan",
                "planner",
                "decomposition",
                "task decomposition"
            ]
        },
        {
            "tag": "reasoning",
            "keywords": [
                "reasoning",
                "chain-of-thought",
                "cot",
                "self-consistency",
                "reflection"
            ]
        }
    ],
    "numeric_tag": "numbers",
    "numeric_pattern": "\\b\\d+(?:\\.\\d+)?%?\\b"
}